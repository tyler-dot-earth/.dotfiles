# Resolve this file's directory reliably when sourced from ~/.zshrc.
ZSHRC_DIR="${${(%):-%N}:A:h}"

# Set ZSH_DEBUG_STARTUP=1 before starting zsh to log optional startup decisions.
source "$ZSHRC_DIR/init.sh"

# opencode
export PATH=~/.opencode/bin:$PATH

# LM Studio
export PATH="$PATH:~/.lmstudio/bin"
